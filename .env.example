# --- LLM provider ---
# Default: groq + Qwen 3 32B (Apache 2.0, open weights, fast).
# Get a free key at https://console.groq.com/keys
VOICEFUL_LLM_PROVIDER=groq

# Groq (recommended)
GROQ_API_KEY=
# Pick one. Confirm exact ID from https://console.groq.com/docs/models
VOICEFUL_GROQ_MODEL=qwen/qwen3-32b
# Alternatives:
# VOICEFUL_GROQ_MODEL=llama-3.3-70b-versatile     # bigger, Llama license
# VOICEFUL_GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# VOICEFUL_GROQ_MODEL=openai/gpt-oss-120b
# VOICEFUL_GROQ_MODEL=openai/gpt-oss-20b
# VOICEFUL_GROQ_MODEL=llama-3.1-8b-instant        # fastest, weakest voice

# Hugging Face Inference API (Apache 2.0 Mistral, free tier, slower cold start)
HF_TOKEN=
VOICEFUL_HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# OpenRouter (paid, wide selection)
OPENROUTER_API_KEY=
VOICEFUL_OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# Together AI (paid)
TOGETHER_API_KEY=
VOICEFUL_TOGETHER_MODEL=Qwen/Qwen2.5-72B-Instruct-Turbo

# Anthropic (closed source, optional alt only)
ANTHROPIC_API_KEY=

# --- Telegram ---
# Create bot via @BotFather on Telegram, copy the token below.
# Send any message to your bot, then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and copy the chat.id from the JSON response.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- App ---
VOICEFUL_LOG_LEVEL=INFO
VOICEFUL_HOME=~/.openclaw/voiceful
